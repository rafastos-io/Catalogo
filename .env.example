# URL do banco Turso (libsql://...)
TURSO_DATABASE_URL=libsql://catalogo-imoveis-XXXX.turso.io

# Token de acesso ao banco (full-access)
TURSO_AUTH_TOKEN=eyJ...

# URL do feed XML externo de imóveis
IMOVEIS_XML_URL=https://example.com/feed_imoveis.xml

# Storage das capas — SFTP na Hostinger (Business+ tem 50 GB + CDN)
# hPanel → Arquivos → Contas FTP (criar conta dedicada so pra capas/)
# hPanel → Avançado → Acesso SSH (ativar — porta SFTP varia, confira no painel)
# STORAGE_REMOTE_DIR = caminho absoluto da pasta capas/ no Gerenciador de Arquivos
STORAGE_SFTP_HOST=srvXXX.main-hosting.eu
STORAGE_SFTP_PORT=65002
STORAGE_SFTP_USER=u123456789
STORAGE_SFTP_PASS=sua_senha_aqui
STORAGE_PUBLIC_URL=https://capas.seudominio.com.br
STORAGE_REMOTE_DIR=/home/u123456789/domains/seudominio.com.br/public_html/capas